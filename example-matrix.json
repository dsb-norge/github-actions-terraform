  {
    "environment": [
      "sandbox"
    ],
    "include": [
      {
        "environment": "sandbox",
        "vars": {
          "environment": "sandbox",
          "runs-on": "tf-platform-sandbox",
          "url": "https://github.com/dsb-norge/azure-terraform-dsb-platform-sandbox/blob/main/envs/sandbox/main.tf",
          "project-dir": "./envs/sandbox",
          "add-pr-comment": "true",
          "format-check-in-root-dir": "false",
          "pr-auto-merge-enabled": "true",
          "terraform-version": "1.13.x",
          "tflint-version": "v0.59.1",
          "github-environment": "sandbox",
          "allow-failing-terraform-operations": false,
          "goals": [
            "all"
          ],
          "terraform-init-additional-dirs": [
            "./main",
            "./modules/azure-ipam-infra"
          ],
          "extra-envs-from-secrets": {},
          "extra-envs": {
            "ARM_USE_OIDC": true,
            "ARM_USE_AZUREAD": true,
            "ARM_TENANT_ID": "93d155bd-6282-4a3c-8d5e-82ba9b074f99",
            "ARM_CLIENT_ID": "a5aa9316-9533-4517-bebd-9500276bac02",
            "ARM_SUBSCRIPTION_ID": "3c981fb2-ff33-46ad-9234-d81fc8daa7a4"
          },
          "pr-auto-merge-from-actors": [
            "dependabot[bot]",
            "Laffs2k5"
          ],
          "pr-auto-merge-limits": {
            "plan-max-count-add": 0,
            "plan-max-count-change": -1,
            "plan-max-count-destroy": 0,
            "plan-max-count-import": 10000,
            "plan-max-count-move": 10000,
            "plan-max-count-remove": -1
          },
          "caller-repo-default-branch": "main",
          "caller-repo-calling-branch": "60/merge",
          "caller-repo-is-on-default-branch": "false"
        }
      }
    ]
  }